---
const currentPath = Astro.url.pathname;

const getActiveClass = (path) => {
  if (currentPath === path) return 'active';
  if (path !== '/' && currentPath.startsWith(path)) return 'active';
  return '';
};
---

<div class="top-bar">
  <div class="container-fluid d-flex justify-content-between align-items-center px-lg-5">
    <div className="company-logo">
      <a href="/" title="AEM Autos">
        <img 
          className="img-fluid" 
          src="/assets/images/logos/logo.webp" 
          alt="AEM Autos" 
          style="width: 220px; height: auto;" 
          width="220" 
          height="47"
          decoding="async"
        />
      </a>
    </div>
    <div class="search-area d-none d-md-block">
      <form method="get" action="#">
        <div class="form-inner">
          <input type="text" placeholder="¿Qué vehículo buscas?" />
          <button type="submit"><i class="bi bi-search"></i></button>
        </div>
      </form>
    </div>
    <div class="topbar-right">
      <ul class="d-flex align-items-center list-unstyled m-0 gap-3">
        <li>
          <a class="primary-btn1" href="https://wa.me/18099973787" target="_blank" rel="noreferrer">
            <i class="bi bi-whatsapp me-2"></i> WHATSAPP
          </a>
        </li>
        <li>
          <a class="primary-btn1" href="tel:+18299823787">
            <i class="bi bi-telephone-fill me-2"></i> LLAMAR
          </a>
        </li>
      </ul>
    </div>
  </div>
</div>

<header class="header-area style-1 sticky-header" id="main-header">
  <div class="container-fluid d-lg-none">
    <div class="d-flex justify-content-between align-items-center py-2 px-1">
      <div class="header-logo">
        <a href="/"><img src="/assets/images/logos/logo-footer.webp" alt="Logo" style="height: 40px;" /></a>
      </div>
      <div class="mobile-menu-btn-wrapper">
        <div class="sidebar-button mobile-menu-btn" id="menu-toggle">
          <span></span>
        </div>
      </div>
    </div>
  </div>
  
  <div class="main-menu" id="mobile-menu">
    <div class="mobile-logo-area d-lg-none d-flex justify-content-between align-items-center">
      <div class="mobile-logo-wrap">
        <a href="/"><img class="img-fluid" src="/assets/images/logos/logo-footer.webp" alt="Logo" style="height: 45px;" /></a>
      </div>
      <div class="menu-close-btn" id="close-menu">
         <i class="bi bi-x-lg fs-2 text-dark"></i>
      </div>
    </div>
    <div class="menu-main-menu-container">
      <ul class="menu-list">
        <li class="menu-item"><a href="/" class={getActiveClass('/')}>INICIO</a></li>
        <li class="menu-item"><a href="/vehiculos" class={getActiveClass('/vehiculos')}>VEHÍCULOS</a></li>
        <li class="menu-item"><a href="/nosotros" class={getActiveClass('/nosotros')}>NOSOTROS</a></li>
        <li class="menu-item"><a href="/financiamiento" class={getActiveClass('/financiamiento')}>FINANCIAMIENTO</a></li>
        <li class="menu-item"><a href="/contacto" class={getActiveClass('/contacto')}>CONTACTO</a></li>
      </ul>
    </div>
  </div>

  <div class="nav-right d-none d-lg-flex justify-content-end align-items-center">
  </div>
</header>

<style is:global>
  .mobile-menu-btn {
    cursor: pointer;
    width: 25px;
    height: 20px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu-btn span,
  .mobile-menu-btn span::before,
  .mobile-menu-btn span::after {
    display: block;
    width: 25px;
    height: 2px;
    background-color: #ffffff !important;
    position: absolute;
    transition: all 0.3s ease;
  }

  .mobile-menu-btn span::before {
    content: "";
    top: -8px;
  }

  .mobile-menu-btn span::after {
    content: "";
    top: 8px;
  }

  .mobile-menu-btn.active span {
    background-color: transparent !important;
  }

  .mobile-menu-btn.active span::before {
    top: 0;
    transform: rotate(45deg);
  }

  .mobile-menu-btn.active span::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (max-width: 991px) {
    .header-area {
      background-color: #000000 !important;
    }
    .mobile-menu-btn-wrapper {
      padding-right: 5px;
    }
  }
</style>

<script>
  (function() {
    const menuToggle = document.getElementById('menu-toggle');
    const closeMenu = document.getElementById('close-menu');
    const mobileMenu = document.getElementById('mobile-menu');
    const header = document.getElementById('main-header');

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', () => {
        mobileMenu.classList.toggle('show-menu');
        menuToggle.classList.toggle('active');
      });
    }

    if (closeMenu && mobileMenu && menuToggle) {
      closeMenu.addEventListener('click', () => {
        mobileMenu.classList.remove('show-menu');
        menuToggle.classList.remove('active');
      });
    }

    let scrolling = false;
    window.addEventListener('scroll', () => {
      if (!scrolling) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 50) {
            header?.classList.add('sticky');
          } else {
            header?.classList.remove('sticky');
          }
          scrolling = false;
        });
        scrolling = true;
      }
    }, { passive: true });
  })();
</script>
