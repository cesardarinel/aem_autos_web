---
// src/components/HeroBanner.astro
---
<div class="home6-banner-area" id="inicio">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="banner-content text-start">
          <span class="badge px-3 py-2 mb-3" style="background: rgba(45, 114, 176, 0.1); color: #2D72B0; fontWeight: 700;">
            AEM AUTOS RD
          </span>
          <h1 class="display-4 fw-bold mb-4">
            Vehículos Importados <br class="d-none d-md-block" />
            <span style="color: #2D72B0;">Directo de USA</span>
          </h1>
          <p class="lead mb-5">
            Especialistas en vehículos americanos de alta calidad (AAA+). 
            Ubicados en Santiago con financiamiento disponible.
          </p>
          <div class="d-flex flex-column flex-sm-row gap-3">
            <a href="/vehiculos" class="primary-btn7 w-100 w-sm-auto text-center">VER CATÁLOGO</a>
            <a href="#contacto" class="btn-outline-custom w-100 w-sm-auto text-center">CONTACTO</a>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="banner-img-group position-relative mt-5 mt-lg-0 text-center">
           <div class="hero-img-wrap mx-auto" style="max-width: 100%;">
             <img 
               src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1200&q=80" 
               alt="Vehículo de lujo AEM Autos" 
               class="img-fluid rounded-4 shadow-lg hero-banner-img"
               width="1200"
               height="800"
               loading="eager"
               decoding="sync"
             />
             <div class="position-absolute bottom-0 start-0 bg-white p-3 rounded-4 shadow border m-3 sales-badge">
                <h4 class="mb-0 fw-bold" style="color: #0D3B66;">410+</h4>
                <p class="small mb-0 text-muted">Ventas exitosas</p>
             </div>
           </div>
        </div>
      </div>
    </div>
  </div>
</div>
