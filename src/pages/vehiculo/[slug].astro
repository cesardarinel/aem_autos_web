---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CarDetailClient from '../../components/CarDetailClient';
import FloatingButtons from '../../components/FloatingButtons';
import { getContentEntries } from '../../lib/api';

export async function getStaticPaths() {
  try {
    const entries = await getContentEntries('vehiculo');
    
    if (entries && entries.length > 0) {
      return entries.map(entry => {
        const fullSlug = `${entry.slug}-${entry.id}`;
        return { 
          params: { slug: fullSlug },
          props: { id: entry.id }
        };
      });
    }
  } catch (e) {
    console.error("Error en getStaticPaths:", e);
  }
  
  return [];
}

const { id } = Astro.props;
---

<Layout title="Cargando vehículo | AEM Autos">
  <Header />
  
  <main class="mt-5 pt-lg-5">
    <CarDetailClient vehicleId={id} client:only="react" />
  </main>

  <Footer />
  <FloatingButtons client:idle />
</Layout>
