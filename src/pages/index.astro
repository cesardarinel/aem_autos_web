---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroBanner from '../components/HeroBanner.astro';
import LatestCars from '../components/LatestCars';
import ExploreBrands from '../components/ExploreBrands.astro';
import HowItWorks from '../components/HowItWorks';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons';

// Este es el componente principal de la Home con Astro al 100%
---

<Layout title="AEM Autos | Vehículos Importados Directo de USA">
  <Header />
  
  <main>
    <div id="home-view" data-aos="fade-down">
      <HeroBanner />
    </div>

    <div id="vehiculos" data-aos="fade-up">
      <LatestCars client:visible />
    </div>

    <div id="beneficios" data-aos="fade-up">
      <ExploreBrands />
    </div>

    <div id="como-funciona" data-aos="fade-up">
      <HowItWorks client:visible />
    </div>
    
    <div class="py-5 text-center bg-light">
      <div class="container">
        <h3 class="fw-bold mb-4">¿Buscas un modelo específico?</h3>
        <p class="lead mb-4">Te ayudamos a importar el vehículo que deseas con garantía AAA+.</p>
        <a href="/contacto" class="btn btn-primary btn-lg px-5 py-3 fw-bold">CONTÁCTANOS AHORA</a>
      </div>
    </div>
  </main>

  <Footer />
  <FloatingButtons client:idle />
</Layout>
